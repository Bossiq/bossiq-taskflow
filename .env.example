# TaskFlow Environment Configuration
# Copy this file to .env and fill in the values.

# Server port (default: 3001)
PORT=3001

# Node environment: "development" or "production"
NODE_ENV=development

# Allowed origin for CORS in production (e.g., https://yourdomain.com)
ALLOWED_ORIGIN=*

# JWT signing secret (CHANGE THIS in production!)
JWT_SECRET=taskflow-dev-secret-change-in-prod

# PostgreSQL connection (when set, uses PostgreSQL instead of SQLite)
# DATABASE_URL=postgresql://user:password@host:5432/taskflow

# Email notifications (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=TaskFlow <noreply@taskflow.app>
